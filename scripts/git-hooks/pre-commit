#!/usr/bin/env bash
# Nova Orbit pre-commit guard
# - Block secret/forbidden files from being committed
# - Run typecheck when TS sources changed
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

staged=$(git diff --cached --name-only --diff-filter=ACM)

# 1) forbidden files
forbidden_patterns=(
  '^\.env($|\..*)'
  '^\.nova-orbit/'
  '\.db$'
  '\.pem$'
)

violations=()
while IFS= read -r f; do
  [ -z "$f" ] && continue
  for pat in "${forbidden_patterns[@]}"; do
    if [[ "$f" =~ $pat ]]; then
      violations+=("$f")
      break
    fi
  done
done <<< "$staged"

if [ ${#violations[@]} -gt 0 ]; then
  echo "[pre-commit] ❌ 금지된 파일이 staged 되었습니다:" >&2
  printf '  - %s\n' "${violations[@]}" >&2
  echo "  → unstage 후 다시 시도하세요. (rm/git restore --staged <file>)" >&2
  exit 1
fi

# 2) typecheck (only when TS changed)
ts_changed=false
if printf '%s\n' "$staged" | grep -qE '\.(ts|tsx)$'; then
  ts_changed=true
fi

if [ "$ts_changed" = "true" ]; then
  echo "[pre-commit] typecheck (server)..."
  if ! npm run -s typecheck; then
    echo "[pre-commit] ❌ server typecheck 실패" >&2
    exit 1
  fi

  if printf '%s\n' "$staged" | grep -q '^dashboard/'; then
    echo "[pre-commit] typecheck (dashboard)..."
    if ! (cd dashboard && npx -s tsc --noEmit); then
      echo "[pre-commit] ❌ dashboard typecheck 실패" >&2
      exit 1
    fi
  fi
fi

echo "[pre-commit] ✓ all checks passed"
