{
  "name": "nova-orbit",
  "version": "0.1.0",
  "description": "AI Team Orchestration + Quality Gate for Solo Founders",
  "type": "module",
  "bin": {
    "nova-orbit": "./dist/bin/nova-orbit.js"
  },
  "scripts": {
    "postinstall": "cd dashboard && npm install",
    "prepare": "bash scripts/install-hooks.sh",
    "predev": "bash scripts/predev.sh",
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:dashboard\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:dashboard": "wait-on http://127.0.0.1:7200/api/health && cd dashboard && VITE_WS_URL=ws://127.0.0.1:7200 npx vite --port 5173",
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "tsup",
    "build:dashboard": "cd dashboard && npm run build && mkdir -p ../dist/dashboard && cp -r dist/* ../dist/dashboard/",
    "postbuild": "mkdir -p dist/server/core/nova-rules && cp server/core/nova-rules/*.md dist/server/core/nova-rules/; chmod +x dist/bin/nova-orbit.js",
    "start": "node dist/bin/nova-orbit.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "quality-gate",
    "claude-code",
    "nova"
  ],
  "author": "givepro91",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/givepro91/nova-orbit.git"
  },
  "homepage": "https://github.com/givepro91/nova-orbit",
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
