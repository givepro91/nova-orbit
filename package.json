{
  "name": "crewdeck",
  "version": "0.1.0",
  "description": "AI Team Orchestration + Quality Gate for Solo Founders",
  "type": "module",
  "bin": {
    "crewdeck": "./dist/bin/crewdeck.js",
    "crewdeck-sync": "./dist/bin/crewdeck-sync.js",
    "crewdeck-mcp": "./dist/bin/crewdeck-mcp.js"
  },
  "scripts": {
    "postinstall": "node -e \"if(require('fs').existsSync('dashboard/package.json'))require('child_process').execSync('npm install',{cwd:'dashboard',stdio:'inherit'})\"",
    "prepare": "bash scripts/install-hooks.sh",
    "predev": "bash scripts/predev.sh",
    "dev": "concurrently --kill-others \"npm run dev:server\" \"npm run dev:dashboard\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:dashboard": "wait-on http://127.0.0.1:7200/api/health && cd dashboard && VITE_WS_URL=ws://127.0.0.1:7200 npx vite --port 5173",
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "tsup",
    "build:dashboard": "cd dashboard && npm run build && mkdir -p ../dist/dashboard && cp -r dist/* ../dist/dashboard/",
    "postbuild": "mkdir -p dist/server/core/methodology && cp server/core/methodology/*.md dist/server/core/methodology/; chmod +x dist/bin/crewdeck.js",
    "start": "node dist/bin/crewdeck.js",
    "test": "vitest run",
    "test:e2e": "CREWDECK_TEST_SCOPE=e2e vitest run",
    "test:all": "CREWDECK_TEST_SCOPE=all vitest run",
    "typecheck": "tsc --noEmit",
    "verify:startup": "node scripts/verify-startup.mjs",
    "prepublishOnly": "npm run build && npm run test:all && npm --prefix dashboard test && npm run verify:startup"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "quality-gate",
    "claude-code"
  ],
  "author": "givepro91",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/givepro91/crewdeck.git"
  },
  "homepage": "https://github.com/givepro91/crewdeck",
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
